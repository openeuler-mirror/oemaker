+ * PURPOSE.
+ * See the Mulan PSL v2 for more details.
+ * Author: xiangyuning
+ * Create: 2022-03-02
+ * Description: provide container buffer functions
+!
+
+#!/bin/bash
+
+SELINUX_FLAG=-1
+
+set -e
+function env_record()
+{
+    # 记录环境
+    se_status=$(getenforce)
+    if [ "$se_status" == "Enforcing" ]; then
+        SELINUX_FLAG=1
+    elif [ "$se_status" == "Permissive" ]; then
+        SELINUX_FLAG=0
+    else
+        echo "Selinux status is $se_status, can't restore"
+    fi
+}
+
+function env_restore()
+{
+    # 恢复环境
+    echo "restore environment"
+
+    # 恢复selinux
+    if [ "$SELINUX_FLAG" -ne -1 ]; then
+        setenforce "$SELINUX_FLAG"
+    fi
+}
+
diff --git a/isomaker/img_repo.sh b/isomaker/img_repo.sh
index 9135b39..92fbaea 100644
--- a/isomaker/img_repo.sh
+++ b/isomaker/img_repo.sh
@@ -39,7 +39,7 @@ function create_install_img()
 
     if [ $? != 0 ] ; then
         cat lorax.logfile
-        exit 1
+        return 1
     fi
 }
 
diff --git a/isomaker/oemaker.sh b/isomaker/oemaker.sh
index c5d85fb..fb542f3 100644
--- a/isomaker/oemaker.sh
+++ b/isomaker/oemaker.sh
@@ -29,6 +29,7 @@ source "${CPATH}"/iso.sh
 source "${CPATH}"/rpm.sh
 source "${CPATH}"/img_repo.sh
 source "${CPATH}"/make_debug.sh
+source "${CPATH}"/env_restore.sh
 
 function mkclean()
 {
@@ -56,6 +57,10 @@ function mk_oe_main()
 
     if [ "${ISO_TYPE}" == "netinst" ]; then
         create_install_img
+        if [ $? -ne 0 ]; then
+            echo "create install img failed"
+            return 1
+        fi
         init_config
         if [ $? -ne 0 ]; then
             echo "init config failed"
@@ -71,6 +76,10 @@ function mk_oe_main()
     fi
 
     create_install_img
+    if [ $? -ne 0 ]; then
+        echo "create install img failed"
+        return 1
+    fi
 
     echo "Creating repos..."
     create_repos
@@ -156,8 +165,12 @@ function mk_oe_main()
     return 0
 }
 
+env_record
 mk_oe_main "$@"
 if [ $? -ne 0 ]; then
     echo "make iso failed"
+    env_restore
     exit 1
 fi
+env_restore
+
