 }
 
+env_record
+
 mk_oe_main "$@"
-if [ $? -ne 0 ]; then
+main_ret="$?"
+
+env_restore
+
+if [ "$main_ret" -ne 0 ]; then
     echo "make iso failed"
     exit 1
 fi
